<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.eclipse.rdf4j</groupId>
		<artifactId>rdf4j-queryalgebra</artifactId>
		<version>6.0.0-SNAPSHOT</version>
	</parent>
	<artifactId>rdf4j-queryalgebra-equivalence</artifactId>
	<name>RDF4J: Query algebra - equivalence</name>
	<description>Experimental proof-oriented equivalence checking for RDF4J query algebra.</description>
	<dependencies>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-common-annotation</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-model</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-query</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-queryalgebra-model</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-queryalgebra-json</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-queryalgebra-evaluation</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-queryparser-sparql</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-sail-api</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-sail-memory</artifactId>
			<version>${project.version}</version>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-rio-ntriples</artifactId>
			<version>${project.version}</version>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-rio-trig</artifactId>
			<version>${project.version}</version>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>${project.groupId}</groupId>
			<artifactId>rdf4j-sail-testsuite</artifactId>
			<version>${project.version}</version>
			<scope>test</scope>
		</dependency>
	</dependencies>
	<profiles>
		<profile>
			<id>equivalence-certification-mutation</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.pitest</groupId>
						<artifactId>pitest-maven</artifactId>
						<version>1.25.3</version>
						<configuration>
							<targetClasses>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.AlgebraEquivalenceChecker*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.ProofKernel*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.NormalizationCertificate*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.CertificateStep*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.SemanticsTarget*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.EvaluationOutcome*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.ExactTreeEquality*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.NativeAlgebraSchema*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.SemanticsValidator*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.BoundedCounterexampleFinder*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.LocalCertificateReplayer*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.CertifiedRuleRegistry*</param>
							</targetClasses>
							<targetTests>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.*</param>
								<param>org.eclipse.rdf4j.query.algebra.equivalence.internal.*</param>
							</targetTests>
							<threads>1</threads>
							<timestampedReports>false</timestampedReports>
							<outputFormats>
								<param>XML</param>
								<param>HTML</param>
							</outputFormats>
							<failWhenNoMutations>true</failWhenNoMutations>
							<mutationThreshold>100</mutationThreshold>
						</configuration>
						<dependencies>
							<dependency>
								<groupId>org.pitest</groupId>
								<artifactId>pitest-junit5-plugin</artifactId>
								<version>1.2.3</version>
							</dependency>
						</dependencies>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>
