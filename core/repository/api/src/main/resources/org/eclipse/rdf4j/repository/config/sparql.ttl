#
# RDF4J configuration template for a Repository proxy for a SPARQL endpoint
#
# @workbench.template label="SPARQL endpoint proxy" order=160
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.

[] a config:Repository ;
    config:rep.impl [
        config:rep.type "openrdf:SPARQLRepository" ;
        config:sparql.queryEndpoint <{%SPARQL query endpoint[len=48 placeholder="http://example.org/sparql"]|%}> ;
        config:sparql.updateEndpoint <{%SPARQL update endpoint[len=48 placeholder="http://example.org/update"]|%}> ;
    ];
    config:rep.id "{%Local repository ID[len=16]|endpoint@localhost%}" ;
    rdfs:label "{%Repository title[len=48]|SPARQL endpoint proxy @localhost%}" .
