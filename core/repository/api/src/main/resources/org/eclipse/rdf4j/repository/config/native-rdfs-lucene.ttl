#
# RDF4J configuration template for a native repository with
# RDFS support and a Lucene index
#
# @workbench.template label="Native Store + RDFS and Lucene" order=120
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.

[] a config:Repository ;
    config:rep.id "{%Repository ID[len=16]|native-rdfs-lucene%}" ;
    rdfs:label "{%Repository title[len=48]|Native store with RDFS entailment and  Lucene Support%}" ;
    config:rep.impl [
        config:rep.type "openrdf:SailRepository" ;
        config:sail.impl [
            config:sail.type "openrdf:LuceneSail";
            config:lucene.indexDir "index/" ;
            config:delegate [
                config:sail.type "rdf4j:SchemaCachingRDFSInferencer" ;
                config:delegate [
                    config:sail.type "openrdf:NativeStore" ;
                    config:sail.iterationCacheSyncThreshold "{%Query Iteration Cache sync threshold[len=16]|10000%}";
                    config:native.tripleIndexes "{%Triple indexes[len=16]|spoc,posc%}";
                    config:sail.defaultQueryEvaluationMode "{%Query Evaluation Mode|STRICT|STANDARD%}"
                ]
            ]
        ]
    ].
