#
# Configuration template for an LmdbStore
#
# @workbench.template label="LMDB Store" order=180
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.
@prefix lmdb: <http://rdf4j.org/config/sail/lmdb#>.

[] a config:Repository ;
   config:rep.id "{%Repository ID|lmdb%}" ;
   # @workbench.field len=16
   rdfs:label "{%Repository title|LMDB Store%}" ;
   # @workbench.field len=48
   config:rep.impl [
      config:rep.type "openrdf:SailRepository" ;
      config:sail.impl [
         config:sail.type "rdf4j:LmdbStore" ;
         config:sail.iterationCacheSyncThreshold {%Query Iteration Cache sync threshold|2097152%} ; # If each value is 128 bytes, this is 256 MB
         # @workbench.field len=16
         config:sail.slowQueryLogThresholdSeconds "{%Slow query log threshold (seconds)|0%}" ;
         # @workbench.field len=16
         config:sail.slowQueryLogFirstResultThresholdSeconds "{%Slow query first-result threshold (seconds)|0%}" ;
         # @workbench.field len=16
         config:sail.slowQueryLogFile "{%Slow query log file|%}" ;
         # @workbench.field len=48
         lmdb:tripleIndexes "{%Triple indexes|spoc,posc,ospc%}" ;
         # @workbench.field len=16
         lmdb:bulkOperationSize {%Bulk operation size|256%} ;
         # @workbench.field len=16
         lmdb:tripleDBSize {%Triple DB size|1073741824%} ; # 1 GB
         # @workbench.field len=16
         lmdb:valueDBSize {%Value DB size|1073741824%} ; # 1 GB
         # @workbench.field len=16
         lmdb:valueCacheSize {%Value cache size|4096%} ;
         # @workbench.field len=16
         lmdb:valueIDCacheSize {%Value ID cache size|4096%} ;
         # @workbench.field len=16
         lmdb:namespaceCacheSize {%Namespace cache size|128%} ;
         # @workbench.field len=16
         lmdb:namespaceIDCacheSize {%Namespace ID cache size|128%} ;
         # @workbench.field len=16
         lmdb:autoGrow {%Auto grow|true|false%} ;
         lmdb:pageCardinalityEstimator {%Page cardinality estimator|true|false%} ;
         lmdb:valueEvictionInterval {%Value eviction interval|300000%} ;
         lmdb:valueHashCacheEnabled {%Value hash cache enabled|false|true%} ;
         lmdb:inlineLiterals {%Inline literals|true|false%} ;
         lmdb:predicateGuaranteeIndexEnabled {%Predicate guarantee index|true|false%} ;
         lmdb:predicateGuaranteeIndexAutoRebuild {%Predicate guarantee rebuild on startup|true|false%} ;
         lmdb:predicateGuaranteeExcludedPredicates "{%Predicate guarantee excluded predicates|%}" ;
         # @workbench.field len=80
         lmdb:sketchEstimatorEnabled {%Sketch estimator enabled|true|false%} ;
         # @workbench.field unset=true
         lmdb:sketchEstimatorSubjectBucketCount {%Sketch estimator subject bucket count|4096%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorPredicateBucketCount {%Sketch estimator predicate bucket count|64%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorObjectBucketCount {%Sketch estimator object bucket count|4096%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorContextBucketCount {%Sketch estimator context bucket count|16%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorOmniWitnessCohortBucketCount {%Sketch estimator OMNI witness cohort bucket count|16%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorOmniWitnessCohortBucketIndex {%Sketch estimator OMNI witness cohort bucket index|7%} ;
         lmdb:sketchEstimatorContextPairSketchesEnabled {%Sketch estimator context pair sketches enabled|false|true%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorThrottleEveryN {%Sketch estimator throttle every N|1048576%} ;
         # @workbench.field len=16
         lmdb:sketchEstimatorThrottleMillis {%Sketch estimator throttle millis|2%} ;
         lmdb:optimizerSamplingEnabled {%Optimizer sampling enabled|true|false%} ;
         # @workbench.field len=16
         lmdb:optimizerSamplingMaxMillis {%Optimizer sampling max millis|2%} ;
         # @workbench.field len=16
         lmdb:optimizerSamplingMaxRows {%Optimizer sampling max rows|4096%} ;
         lmdb:backgroundRawSamplingEnabled {%Background raw sampling enabled|true|false%} ;
         # @workbench.field len=16
         lmdb:backgroundRawSamplingMaxMillisPerCycle {%Background raw sampling max millis per cycle|10%} ;
         # @workbench.field len=16
         lmdb:forceSync {%Force sync|false|true%} ;
         lmdb:noReadahead {%No readahead|false|true%} ;
         config:sail.defaultQueryEvaluationMode "{%Query Evaluation Mode|STANDARD|STRICT%}";
      ]
   ].
