#
# Configuration template for an LmdbStore
#
# @workbench.template label="LMDB Store" order=180
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix config: <tag:rdf4j.org,2023:config/>.
@prefix lmdb: <http://rdf4j.org/config/sail/lmdb#>.

[] a config:Repository ;
   config:rep.id "{%Repository ID[len=16]|lmdb%}" ;
   rdfs:label "{%Repository title[len=48]|LMDB Store%}" ;
   config:rep.impl [
      config:rep.type "openrdf:SailRepository" ;
      config:sail.impl [
         config:sail.type "rdf4j:LmdbStore" ;
         config:sail.iterationCacheSyncThreshold {%Query Iteration Cache sync threshold[len=16]|2097152%} ; # If each value is 128 bytes, this is 256 MB
         lmdb:tripleIndexes "{%Triple indexes[len=16]|spoc,posc,ospc,cspo%}" ; #cspo good when using named graphs
         lmdb:tripleDBSize {%Triple DB size[len=16]|1099511627776%} ; # 1 TB
         lmdb:valueDBSize {%Value DB size[len=16]|1099511627776%} ; # 1 TB
         lmdb:valueCacheSize {%Value cache size[len=16]|4096%} ;
         lmdb:valueIDCacheSize {%Value ID cache size[len=16]|4096%} ;
         lmdb:namespaceCacheSize {%Namespace cache size[len=16]|128%} ;
         lmdb:namespaceIDCacheSize {%Namespace ID cache size[len=16]|128%} ;
         lmdb:autoGrow {%Auto grow|true|false%} ;
         lmdb:pageCardinalityEstimator {%Page cardinality estimator|true|false%} ;
         lmdb:valueEvictionInterval {%Value eviction interval[len=16]|300000%} ;
         lmdb:forceSync {%Force sync|false|true%} ;
         lmdb:noReadahead {%No readahead|false|true%} ;
         config:sail.defaultQueryEvaluationMode "{%Query Evaluation Mode|STRICT|STANDARD%}";
      ]
   ].
