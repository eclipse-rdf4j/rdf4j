<#q01> a mf:QueryEvaluationTest ;
   mf:name "OPTIONAL introduces a possibly unbound variable" ;
   mf:action [ qt:query <queries/q01.rq> ; ss:dataset <data/scope-data.trig> ] ;
   mf:result <results/q01.srx> ;
   ss:ordered false ;
   ss:category "boundness" .

<#q02> a mf:QueryEvaluationTest ;
   mf:name "UNION branch-only bindings" ;
   mf:action [ qt:query <queries/q02.rq> ; ss:dataset <data/scope-data.trig> ] ;
   mf:result <results/q02.srx> ;
   ss:ordered false ;
   ss:category "union" .

<#q03> a mf:QueryEvaluationTest ;
   mf:name "VALUES UNDEF can be supplied by a later join" ;
   mf:action [ qt:query <queries/q03.rq> ; ss:dataset <data/scope-data.trig> ] ;
   mf:result <results/q03.srx> ;
   ss:ordered false ;
   ss:category "values" .

<#q04> a mf:QueryEvaluationTest ;
   mf:name "VALUES binding constrains OPTIONAL compatibility" ;
   mf:action [ qt:query <queries/q04.rq> ; ss:dataset <data/scope-data.trig> ] ;
   mf:result <results/q04.srx> ;
   ss:ordered false ;
   ss:category "values" .

<#q05> a mf:QueryEvaluationTest ;
