   mf:result <results/q06.srx> ;
   ss:ordered false ;
   ss:category "bind" .

<#q07> a mf:QueryEvaluationTest ;
   mf:name "FILTER textual position within one group" ;
   mf:action [ qt:query <queries/q07.rq> ; ss:dataset <data/scope-data.trig> ] ;
   mf:result <results/q07.srx> ;
   ss:ordered false ;
   ss:category "filter" .

<#q08> a mf:QueryEvaluationTest ;
   mf:name "Nested ordinary group is not lateral" ;
